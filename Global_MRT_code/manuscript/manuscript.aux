\@writefile{lof}{\contentsline {figure}{\numberline {S2}{\ignorespaces \textbf  {Multi-panel comparison of predicted mean transit time across all seven model configurations (M1--M7).} Log-scale colour palette as in Fig.\nobreakspace  {}\ref {fig:global_mrt}. Progressive addition of variable groups visually resolves spatial structure that the climate-only baseline (M1) cannot capture. }}{34}{figure.2}\protected@file@percent }
\newlabel{fig:model_maps}{{S2}{34}{\textbf {Multi-panel comparison of predicted mean transit time across all seven model configurations (M1--M7).} Log-scale colour palette as in Fig.~\ref {fig:global_mrt}. Progressive addition of variable groups visually resolves spatial structure that the climate-only baseline (M1) cannot capture}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {S3}{\ignorespaces \textbf  {Absolute latitudinal profile of soil carbon turnover time: CMIP6 ensemble and RF\nobreakspace  {}M7.} Area-weighted zonal-mean $\tau $ (years, logarithmic axis) for each of the six CMIP6 models (muted colours), the six-member ensemble mean (dashed blue), and the RF\nobreakspace  {}M7 prediction from this study (solid red). Light blue shading denotes the inter-model spread (minimum to maximum across the six CMIP6 members in each latitude band). CMIP6 outputs are historical climatological means 1980--2014. The much wider dynamic range of CMIP6 models relative to RF\nobreakspace  {}M7 is the magnitude counterpart to the structural comparison shown in Fig.\nobreakspace  {}\ref {fig:esm_heatmap}. }}{35}{figure.3}\protected@file@percent }
\newlabel{fig:esm_profile}{{S3}{35}{\textbf {Absolute latitudinal profile of soil carbon turnover time: CMIP6 ensemble and RF~M7.} Area-weighted zonal-mean $\tau $ (years, logarithmic axis) for each of the six CMIP6 models (muted colours), the six-member ensemble mean (dashed blue), and the RF~M7 prediction from this study (solid red). Light blue shading denotes the inter-model spread (minimum to maximum across the six CMIP6 members in each latitude band). CMIP6 outputs are historical climatological means 1980--2014. The much wider dynamic range of CMIP6 models relative to RF~M7 is the magnitude counterpart to the structural comparison shown in Fig.~\ref {fig:esm_heatmap}}{figure.3}{}}
