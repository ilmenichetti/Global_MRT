\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Attribution of variance among process classes.} Single-domain skill, coalition build-up, and order-independent Shapley shares (Climate\nobreakspace  {}35, Edaphic\nobreakspace  {}33, Biological\nobreakspace  {}22, Land use\nobreakspace  {}10\,\%) on the common row set ($n=154{,}675$). The full model sits well below the sum of single-domain skills: the overlap that marks correlated-but-not-redundant predictors.}}{18}{figure.1}\protected@file@percent }
\newlabel{fig:shapley}{{1}{18}{\textbf {Attribution of variance among process classes.} Single-domain skill, coalition build-up, and order-independent Shapley shares (Climate~35, Edaphic~33, Biological~22, Land use~10\,\%) on the common row set ($n=154{,}675$). The full model sits well below the sum of single-domain skills: the overlap that marks correlated-but-not-redundant predictors}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Spatial organisation of the beyond-climate residual}{19}{subsection.3.3}\protected@file@percent }
\newlabel{sec:results_moran}{{3.3}{19}{Spatial organisation of the beyond-climate residual}{subsection.3.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Spatial organisation of the beyond-climate residual.} How to read it: each point is a 2\textdegree {} block; the horizontal axis is that block's mean beyond-climate residual (observed minus climate-only prediction), and the vertical axis is the average residual of its neighbouring blocks. A positive slope means blocks resemble their neighbours more than a random arrangement would give (spatial clustering) and the slope is Moran's $I=0.25$ ($p\ll 0.001$). A flat, shapeless cloud would indicate no spatial organisation. Points are coloured by each block's modal coarse K\"oppen zone (A tropical, B arid, C temperate, D cold, E polar); the beyond-climate autocorrelation is broadly distributed across zones rather than confined to one.}}{20}{figure.2}\protected@file@percent }
\newlabel{fig:moran}{{2}{20}{\textbf {Spatial organisation of the beyond-climate residual.} How to read it: each point is a 2\textdegree {} block; the horizontal axis is that block's mean beyond-climate residual (observed minus climate-only prediction), and the vertical axis is the average residual of its neighbouring blocks. A positive slope means blocks resemble their neighbours more than a random arrangement would give (spatial clustering) and the slope is Moran's $I=0.25$ ($p\ll 0.001$). A flat, shapeless cloud would indicate no spatial organisation. Points are coloured by each block's modal coarse K\"oppen zone (A tropical, B arid, C temperate, D cold, E polar); the beyond-climate autocorrelation is broadly distributed across zones rather than confined to one}{figure.2}{}}
