\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {ESM structural comparison.} Relative soil-carbon turnover, each product normalised to its own global mean, shown (a)\nobreakspace  {}by biome zone and (b)\nobreakspace  {}as continuous latitudinal profiles (the same information, read discretely and continuously). Our estimate (RF, bold red) stays near its global mean across zones and latitudes, whereas the CMIP6 models rise steeply toward the poles (median polar/tropical contrast $\sim $9$\times $ vs $\sim $2.5$\times $ for RF; range 0.6--14$\times $, including an inverted MPI gradient).}}{25}{figure.5}\protected@file@percent }
\newlabel{fig:esm_biome}{{5}{25}{\textbf {ESM structural comparison.} Relative soil-carbon turnover, each product normalised to its own global mean, shown (a)~by biome zone and (b)~as continuous latitudinal profiles (the same information, read discretely and continuously). Our estimate (RF, bold red) stays near its global mean across zones and latitudes, whereas the CMIP6 models rise steeply toward the poles (median polar/tropical contrast $\sim $9$\times $ vs $\sim $2.5$\times $ for RF; range 0.6--14$\times $, including an inverted MPI gradient)}{figure.5}{}}
