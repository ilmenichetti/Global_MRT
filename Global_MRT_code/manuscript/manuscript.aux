\newlabel{fig:ale_latband}{{7}{31}{\textbf {Latitude-band stratification of ALE response curves for the ten most responsive predictors.}}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Relative latitudinal structure of soil carbon turnover time across the CMIP6 ensemble and the observation-constrained estimate.} Zonal-mean $\tau $ in 1\textdegree {} latitude bands (area-weighted) is shown for the CMIP6 six-member ensemble mean, each individual CMIP6 model (with its land surface model in parentheses), and the RF\nobreakspace  {}M7 prediction from this study. Each column has been min--max normalised to the interval $[0, 1]$ (0\nobreakspace  {}=\nobreakspace  {}the shortest zonal $\tau $ produced by that product; 1\nobreakspace  {}=\nobreakspace  {}the longest). This normalisation equalises the absolute range across products and exposes differences in the \emph  {spatial organisation} of $\tau $ but necessarily compresses magnitude information; see Fig.\nobreakspace  {}\ref {fig:esm_profile} and Table\nobreakspace  {}\ref {tab:esm_dispersion} (Appendix) for the corresponding magnitude comparison. CMIP6 outputs are 1980--2014 climatological means; RF\nobreakspace  {}M7 prediction at 0.1\textdegree {} was aggregated to 1\textdegree {} for this comparison. }}{32}{figure.8}\protected@file@percent }
\newlabel{fig:esm_heatmap}{{8}{32}{\textbf {Relative latitudinal structure of soil carbon turnover time across the CMIP6 ensemble and the observation-constrained estimate.} Zonal-mean $\tau $ in 1\textdegree {} latitude bands (area-weighted) is shown for the CMIP6 six-member ensemble mean, each individual CMIP6 model (with its land surface model in parentheses), and the RF~M7 prediction from this study. Each column has been min--max normalised to the interval $[0, 1]$ (0~=~the shortest zonal $\tau $ produced by that product; 1~=~the longest). This normalisation equalises the absolute range across products and exposes differences in the \emph {spatial organisation} of $\tau $ but necessarily compresses magnitude information; see Fig.~\ref {fig:esm_profile} and Table~\ref {tab:esm_dispersion} (Appendix) for the corresponding magnitude comparison. CMIP6 outputs are 1980--2014 climatological means; RF~M7 prediction at 0.1\textdegree {} was aggregated to 1\textdegree {} for this comparison}{figure.8}{}}
